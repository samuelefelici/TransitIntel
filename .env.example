# ─── Database (Neon.tech free tier) ──────────────────────────
# Vai su https://neon.tech → crea progetto → copia connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── API Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CRON Secret (genera con: openssl rand -hex 32) ─────────
CRON_SECRET=your-secret-here

# ─── TomTom Traffic API ─────────────────────────────────────
# https://developer.tomtom.com → registrati → copia API key
TOMTOM_API_KEY=

# ─── Google Places API (opzionale, per sync POI) ────────────
# https://console.cloud.google.com → API & Services → Places API
GOOGLE_PLACES_API_KEY=

# ─── Mapbox (frontend) ──────────────────────────────────────
# https://account.mapbox.com → copia default public token
MAPBOX_TOKEN=

# ─── Bounding Box Provincia di Ancona ────────────────────────
PROVINCE_BBOX=12.7,43.2,13.65,43.95

# ─── Frontend URL (per CORS) ─────────────────────────────────
# In produzione sarà tipo: https://transitintel.vercel.app
FRONTEND_URL=http://localhost:5173
